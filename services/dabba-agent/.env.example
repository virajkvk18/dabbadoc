# Dabba Agent config
APP_ENV=development
API_AUTH_TOKEN=generate-a-long-random-token
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=60
MAX_JSON_MB=10
MAX_IMAGE_MB=7

# LLM keys - keep these on backend only
GEMINI_API_KEY=your_gemini_api_key_here
GROK_API_KEY=your_xai_grok_api_key_here

# Models
GEMINI_MODEL=gemini-2.5-flash
GROK_MODEL=grok-4
ENABLE_GROK_FALLBACK=true

# Defaults
DEFAULT_LANGUAGE=hinglish
