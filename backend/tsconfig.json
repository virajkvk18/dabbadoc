{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "declaration": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "incremental": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
